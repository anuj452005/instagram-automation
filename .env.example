# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database (Cloud PostgreSQL URL)
DATABASE_URL=postgresql://username:password@your-cloud-db-host:5432/database_name?sslmode=require

# Redis (Cloud Redis URL)
REDIS_URL=rediss://default:password@your-cloud-redis-host:6379

# Clerk Auth
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Meta / Instagram App
MOCK_META_API=false
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=gramflow_verify_token

# Security Keys
# Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_hex_char_key_here
# Generate JWT_SECRET:     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_hex_char_jwt_secret_here
